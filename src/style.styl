// Variables
$black = #0e101a
$brand-dark = #1f3042
$slat-horizontal-margin-mobile = 16px
$slat-vertical-margin-mobile = 48px
$slat-horizontal-margin-desktop = 40px
$slat-vertical-margin-desktop = 128px

// Base styles
html
    scroll-behavior smooth

:root
    --black: $black
    --brand-dark: $brand-dark
    --slat-horizontal-margin: $slat-horizontal-margin-mobile
    --slat-vertical-margin: $slat-vertical-margin-mobile

body
    font-family "DM Sans", sans-serif
    color $brand-dark
    margin 0
    padding 0
    box-sizing border-box

// Mobile styles (default)
.slat
    padding var(--slat-vertical-margin) var(--slat-horizontal-margin)

#overview
    background-image url("./assets/images/overview-bg.jpg")
    background-repeat no-repeat
    background-position bottom right
    background-size contain
    display flex
    height 850px
    padding 0 var(--slat-horizontal-margin)
    flex-direction column
    align-items flex-start
    gap 64px
    align-self stretch

.navbar
    display flex
    padding 24px var(--slat-horizontal-margin)
    justify-content space-between
    align-items center
    align-self stretch
    background-color #ffffff

.nav-logo a
    text-decoration none
    font-weight bold
    color var(--black)
    font-size 1.25rem

.desktop-only
    display none

.mobile-only
    display block
    cursor pointer

// Mobile Menu Styles
.mobile-menu
    position fixed
    top 0
    left 0
    width 100%
    height 100%
    background-color #ffffff
    z-index 1000
    display none
    flex-direction column

    &.active
        display flex

.mobile-menu-header
    display flex
    justify-content space-between
    align-items center
    padding 24px var(--slat-horizontal-margin)
    border-bottom 1px solid #dddddd

.mobile-menu-close
    cursor pointer
    color var(--black)

.mobile-nav-links
    list-style none
    padding 40px var(--slat-horizontal-margin)
    margin 0

    li
        margin-bottom 24px

    a
        text-decoration none
        color var(--brand-dark)
        font-size 1.5rem
        font-weight 500

h1, h2, h3, h4, h5, h6
    color var(--black)
    margin-top 0
    margin-bottom 1rem
    line-height 1.2
    font-weight 700

h1
    font-size 2.5rem
h2
    font-size 2rem
h3
    font-size 1.75rem
h4
    font-size 1.5rem
h5
    font-size 1.25rem
h6
    font-size 1rem

p
    color var(--brand-dark)
    font-size 1rem
    line-height 1.6
    margin-bottom 1.5rem
    font-weight 400

    &:last-child
        margin-bottom 0

small
    font-size 0.875rem
    color var(--brand-dark)
    line-height 1.4

// Tablet breakpoint
@media (min-width: 768px)
    h1
        font-size 3rem
    h2
        font-size 2.5rem
    h3
        font-size 2.125rem
    h4
        font-size 1.75rem
    p
        font-size 1.125rem

// Desktop breakpoint
@media (min-width: 1024px)
    :root
        --slat-horizontal-margin: $slat-horizontal-margin-desktop
        --slat-vertical-margin: $slat-vertical-margin-desktop

    .desktop-only
        display flex

    .mobile-only
        display none

    .mobile-menu
        display none !important

    .nav-links
        list-style none
        display flex
        gap 20px
        margin 0
        padding 0

        a
            text-decoration none
            color var(--brand-dark)

    #overview
        display flex
        height 1308px
        padding var(--slat-vertical-margin) 64px 0 var(--slat-vertical-margin)
        flex-direction column
        align-items flex-start
        gap 80px
        align-self stretch

    h1
        font-size 3.5rem
    h2
        font-size 3rem
    h3
        font-size 2.5rem
    h4
        font-size 2rem
    p
        font-size 1.25rem
